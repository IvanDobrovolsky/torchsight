---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="relative flex flex-col items-center px-6 overflow-hidden">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-violet-500/5 rounded-full blur-[120px] pointer-events-none" />

    <img src="/logo.svg" alt="TorchSight" class="w-44 h-44 md:w-52 md:h-52 mt-14 mb-4 drop-shadow-[0_0_40px_rgba(139,92,246,0.15)]" />

    <h1 class="text-2xl md:text-3xl font-light tracking-[0.2em] text-text-secondary/80 mb-2">TORCHSIGHT</h1>

    <p class="text-text-muted text-sm mb-8 text-center max-w-md">
      Open-source security scanner and document classifier powered by local LLMs.
    </p>

    <!-- Links -->
    <div class="flex gap-5 mb-10 text-xs font-mono">
      <a href="https://github.com/IvanDobrovolsky/torchsight" class="text-cyan-400 hover:text-cyan-300 transition-colors">GitHub</a>
      <a href="https://ollama.com" class="text-cyan-400 hover:text-cyan-300 transition-colors">Ollama</a>
      <a href="https://huggingface.co/torchsight" class="text-cyan-400 hover:text-cyan-300 transition-colors">HuggingFace</a>
    </div>

    <!-- Feature pills -->
    <div class="flex flex-wrap justify-center gap-2 mb-12 max-w-lg">
      {[
        'PII Detection', 'Credentials & Secrets', 'Military / Classified',
        'Malicious Payloads', 'Financial & Medical', 'Compliance Mapping',
        '100% Local', 'Open Source',
      ].map(tag => (
        <span class="px-3 py-1.5 text-[13px] font-mono text-text-muted border border-border-visible rounded-full">
          {tag}
        </span>
      ))}
    </div>

    <!-- Video placeholder -->
    <section class="w-full max-w-2xl mb-20">
      <div class="aspect-video bg-surface border border-border-subtle rounded-lg flex items-center justify-center">
        <div class="text-center">
          <svg class="w-12 h-12 mx-auto mb-3 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
          </svg>
          <p class="text-text-dim text-sm font-mono">Demo video coming soon</p>
        </div>
      </div>
    </section>

    <footer class="pb-10 text-center">
      <p class="text-text-dim text-xs font-mono">
        Apache 2.0 &middot; Built with local LLMs &middot; No data leaves your machine
      </p>
    </footer>
  </main>
</Layout>
