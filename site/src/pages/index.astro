---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="relative flex flex-col items-center px-6 overflow-hidden">
    <!-- Ambient glow -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-violet-500/5 rounded-full blur-[120px] pointer-events-none" />
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] bg-cyan-400/5 rounded-full blur-[80px] pointer-events-none" />

    <!-- Logo -->
    <img
      src="/logo.svg"
      alt="TorchSight"
      class="w-64 h-64 md:w-80 md:h-80 mt-16 mb-6 drop-shadow-[0_0_40px_rgba(139,92,246,0.15)]"
    />

    <!-- One-liner -->
    <p class="text-text-muted text-sm mb-10">
      Open-source security scanner powered by local LLMs. Nothing leaves your machine.
    </p>

    <!-- Feature pills -->
    <div class="flex flex-wrap justify-center gap-2 mb-12 max-w-lg">
      {[
        'PII Detection',
        'Credentials & Secrets',
        'Military / Classified',
        'Malicious Payloads',
        'Financial & Medical',
        'Compliance Mapping',
        '100% Local',
        'Open Source',
      ].map(tag => (
        <span class="px-3 py-1 text-xs font-mono text-text-dim border border-border-visible rounded-full">
          {tag}
        </span>
      ))}
    </div>

    <!-- GitHub link -->
    <a
      href="https://github.com/user/torchsight"
      class="flex items-center gap-2 px-5 py-2.5 text-sm text-text-muted border border-border-visible rounded-lg hover:border-violet-600/40 hover:text-violet-400 transition-colors duration-200 mb-20"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      GitHub
    </a>

    <!-- Install snippet -->
    <section id="install" class="w-full max-w-xl mb-20">
      <div class="bg-deep border border-border-subtle rounded-lg overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border-subtle">
          <div class="w-2.5 h-2.5 rounded-full bg-error/60" />
          <div class="w-2.5 h-2.5 rounded-full bg-warning/60" />
          <div class="w-2.5 h-2.5 rounded-full bg-success/60" />
          <span class="ml-2 text-xs text-text-dim font-mono">terminal</span>
        </div>
        <div class="p-5 font-mono text-sm leading-relaxed">
          <p class="text-text-muted mb-1"># clone and install</p>
          <p><span class="text-cyan-400">$</span> <span class="text-text-secondary">git clone https://github.com/user/torchsight</span></p>
          <p><span class="text-cyan-400">$</span> <span class="text-text-secondary">cd torchsight && ./install.sh</span></p>
          <p class="text-text-muted mt-4 mb-1"># scan a directory</p>
          <p><span class="text-cyan-400">$</span> <span class="text-text-secondary">torchsight</span></p>
        </div>
      </div>
    </section>

    <!-- Video placeholder -->
    <section class="w-full max-w-2xl mb-20">
      <div class="aspect-video bg-surface border border-border-subtle rounded-lg flex items-center justify-center">
        <div class="text-center">
          <svg class="w-12 h-12 mx-auto mb-3 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
          </svg>
          <p class="text-text-dim text-sm font-mono">Demo video coming soon</p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="pb-10 text-center">
      <p class="text-text-dim text-xs font-mono">
        Apache 2.0 &middot; Built with local LLMs &middot; No data leaves your machine
      </p>
    </footer>
  </main>
</Layout>
