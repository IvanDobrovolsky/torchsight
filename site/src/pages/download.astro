---
import Layout from '../layouts/Layout.astro';

const version = 'v1.0.0-rc4';
const repo = 'https://github.com/IvanDobrovolsky/torchsight/releases/download';
const links = {
  macos: {
    cli: `${repo}/${version}/torchsight-macos-arm64`,
    cliIntel: `${repo}/${version}/torchsight-macos-x86_64`,
    desktop: `${repo}/${version}/TorchSight-macos-arm64.dmg`,
  },
  linux: {
    cli: `${repo}/${version}/torchsight-linux-x86_64`,
    appimage: `${repo}/${version}/TorchSight-linux-x86_64.AppImage`,
    deb: `${repo}/${version}/TorchSight-linux-x86_64.deb`,
  },
  windows: {
    cli: `${repo}/${version}/torchsight-windows-x86_64.exe`,
    desktop: `${repo}/${version}/TorchSight-windows-x86_64-setup.exe`,
  },
};
---

<Layout title="Download — TorchSight">
  <main class="max-w-2xl mx-auto px-6 py-14">

    <!-- ASCII logo as SVG for pixel-perfect rendering -->
    <div class="flex justify-center mb-4 select-none">
      <svg viewBox="0 0 500 90" class="w-full max-w-md" xmlns="http://www.w3.org/2000/svg">
        <text font-family="'Fira Code', 'Courier New', monospace" font-size="14" fill="#a78bfa" xml:space="preserve">
          <tspan x="20" y="18">   _                _         _       _     _</tspan>
          <tspan x="20" y="34">  | |_ ___  _ _ ___| |_  ___ (_) __ _| |_  | |_</tspan>
          <tspan x="20" y="50">  |  _/ _ \| '_/ __| ' \(_-&lt; | |/ _` | ' \ |  _|</tspan>
          <tspan x="20" y="66">   \__\___/|_| \___|_||_/__/ |_|\__, |_||_|  \__|</tspan>
          <tspan x="20" y="82">                                |___/</tspan>
        </text>
      </svg>
    </div>

    <h1 class="text-3xl md:text-4xl font-mono text-text-primary text-center mb-2">Download TorchSight</h1>
    <p class="text-text-muted text-sm text-center mb-12">On-premise security scanner. Runs locally, no data leaves your machine.</p>

    <!-- OS Selector -->
    <div class="flex justify-center gap-4 mb-12">
      <button id="btn-macos" class="os-btn os-btn-active" data-os="macos">
        <svg class="w-9 h-9 mx-auto mb-2" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        <span class="text-sm font-mono">macOS</span>
      </button>
      <button id="btn-linux" class="os-btn" data-os="linux">
        <svg class="w-9 h-9 mx-auto mb-2" viewBox="0 0 24 24" fill="currentColor"><path d="M12.503.066c-.156 0-.317.008-.481.021C7.795.42 8.924 4.894 8.852 6.385c-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 0 0-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2a2.37 2.37 0 0 0 .114.333l.003.003c.391.778 1.113 1.368 1.884 1.368.39 0 .739-.134 1.107-.534.117-.134.23-.268.346-.469.196-.335.39-.735.585-1.068.376-.4 1.203-.73 1.685-1.068.326-.268.554-.534.554-.936 0-.268-.108-.469-.295-.602a.946.946 0 0 0-.631-.2c-.263 0-.525.068-.725.068-.188 0-.371-.068-.54-.136a1.6 1.6 0 0 1-.228-.2c-.133-.27-.225-.602-.296-.936-.036-.268.028-.602.126-.87.098-.332.296-.602.53-.87l.002-.002c.065-.065.138-.135.22-.2.27-.264.606-.463.72-.733.2-.534.066-1.135-.267-1.467a.89.89 0 0 0-.729-.335c-.39 0-.725.2-1.058.4a.392.392 0 0 1-.198.068.392.392 0 0 1-.198-.068 1.015 1.015 0 0 1-.264-.27c-.148-.198-.158-.462-.062-.734.064-.2.158-.334.254-.534l.003-.003c.066-.133.131-.267.198-.4.265-.534.397-1.068.397-1.535 0-.467-.064-.87-.196-1.267-.127-.4-.388-.8-.73-1.068-.525-.4-1.146-.6-1.757-.6-.616 0-1.16.2-1.55.535-.39.334-.592.667-.592 1.068 0 .135.019.27.052.4.034.132.066.267.097.4.197.535.293 1.068.293 1.468 0 .267-.032.534-.097.8-.064.268-.197.535-.392.735-.39.4-.985.6-1.584.6-.595 0-1.19-.2-1.584-.6-.199-.2-.334-.467-.399-.735a2.478 2.478 0 0 1-.097-.8c0-.4.099-.933.293-1.468.033-.133.066-.268.099-.4.03-.13.049-.265.049-.4 0-.4-.202-.734-.59-1.068-.392-.335-.936-.535-1.553-.535z"/></svg>
        <span class="text-sm font-mono">Linux</span>
      </button>
      <button id="btn-windows" class="os-btn" data-os="windows">
        <svg class="w-9 h-9 mx-auto mb-2" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
        <span class="text-sm font-mono">Windows</span>
      </button>
    </div>

    <!-- macOS content -->
    <div id="panel-macos" class="os-panel">
      <div class="bg-deep border border-border-subtle rounded-lg overflow-hidden mb-6">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border-subtle">
          <div class="w-2.5 h-2.5 rounded-full bg-error/60"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-warning/60"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-success/60"></div>
          <span class="ml-2 text-xs text-text-dim font-mono">terminal</span>
        </div>
        <div class="p-5 relative">
          <pre class="text-sm font-mono text-text-secondary"><code><span class="text-cyan-400">$</span> curl -fsSL https://torchsight.io/install.sh | sh</code></pre>
          <button class="copy-btn absolute top-4 right-4 text-text-dim hover:text-text-secondary" data-copy="curl -fsSL https://torchsight.io/install.sh | sh">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </button>
        </div>
      </div>
      <p class="text-text-dim text-xs text-center mb-6">paste this in terminal</p>
      <p class="text-text-dim text-xs text-center mb-4">or</p>
      <div class="flex flex-col items-center gap-3">
        <a href={links.macos.desktop} class="download-btn">Download for macOS</a>
        <p class="text-text-dim text-xs">Apple Silicon (.dmg) &middot; Requires macOS 12+</p>
        <div class="flex gap-4 mt-2">
          <a href={links.macos.cli} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono">CLI (ARM64)</a>
          <a href={links.macos.cliIntel} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono">CLI (Intel)</a>
        </div>
      </div>
    </div>

    <!-- Linux content -->
    <div id="panel-linux" class="os-panel hidden">
      <div class="bg-deep border border-border-subtle rounded-lg overflow-hidden mb-6">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border-subtle">
          <div class="w-2.5 h-2.5 rounded-full bg-error/60"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-warning/60"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-success/60"></div>
          <span class="ml-2 text-xs text-text-dim font-mono">terminal</span>
        </div>
        <div class="p-5 relative">
          <pre class="text-sm font-mono text-text-secondary"><code><span class="text-cyan-400">$</span> curl -fsSL https://torchsight.io/install.sh | sh</code></pre>
          <button class="copy-btn absolute top-4 right-4 text-text-dim hover:text-text-secondary" data-copy="curl -fsSL https://torchsight.io/install.sh | sh">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </button>
        </div>
      </div>
      <p class="text-text-dim text-xs text-center mb-6">paste this in terminal</p>
      <p class="text-text-dim text-xs text-center mb-4">or</p>
      <div class="flex flex-col items-center gap-3">
        <a href={links.linux.appimage} class="download-btn">Download for Linux</a>
        <p class="text-text-dim text-xs">x86_64 AppImage &middot; Works on most distros</p>
        <div class="flex gap-4 mt-2">
          <a href={links.linux.deb} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono">.deb (Debian/Ubuntu)</a>
          <a href={links.linux.cli} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono">CLI binary</a>
        </div>
      </div>
    </div>

    <!-- Windows content -->
    <div id="panel-windows" class="os-panel hidden">
      <div class="flex flex-col items-center gap-3 mb-8">
        <a href={links.windows.desktop} class="download-btn">Download Desktop App</a>
        <p class="text-text-dim text-xs">Windows 10+ installer (.exe) &middot; Includes GUI + scanner</p>
      </div>
      <div class="flex justify-center gap-4 mb-8">
        <a href={links.windows.cli} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono border border-border-visible rounded-lg px-5 py-2.5 hover:border-violet-500/40 transition-colors">CLI only (.exe)</a>
      </div>

      <div class="bg-deep border border-border-subtle rounded-lg p-5 text-sm text-text-secondary">
        <p class="font-mono text-text-primary text-xs mb-3">Quick Setup (after installing):</p>
        <ol class="space-y-2 text-xs text-text-muted list-decimal list-inside">
          <li>Install <a href="https://ollama.com/download" class="text-cyan-400 hover:text-cyan-300">Ollama for Windows</a></li>
          <li>Open PowerShell and run: <code class="text-text-dim font-mono">ollama pull torchsight/beam</code></li>
          <li>Launch TorchSight from the Start menu</li>
        </ol>
      </div>
    </div>

    <!-- Requirements -->
    <div class="mt-14 border-t border-border-subtle pt-8">
      <h2 class="text-xs font-mono text-violet-400 tracking-widest mb-4">REQUIREMENTS</h2>
      <div class="space-y-4 text-sm text-text-secondary">
        <div class="flex items-start gap-3">
          <span class="text-violet-400 mt-0.5">1.</span>
          <div>
            <p class="font-mono text-text-primary text-sm">Ollama</p>
            <p class="text-text-muted text-xs mt-1">Local LLM runtime. <a href="https://ollama.com/download" class="text-cyan-400 hover:text-cyan-300">Install Ollama</a>, then run:</p>
            <code class="text-xs font-mono text-text-dim mt-1 block">ollama pull torchsight/beam</code>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-violet-400 mt-0.5">2.</span>
          <div>
            <p class="font-mono text-text-primary text-sm">Tesseract OCR <span class="text-text-dim">(optional)</span></p>
            <p class="text-text-muted text-xs mt-1">For image scanning. macOS: <code class="text-xs">brew install tesseract</code></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Version info -->
    <div class="mt-10 text-center">
      <p class="text-text-dim text-xs font-mono">
        {version} &middot; Apache 2.0 &middot;
        <a href={`https://github.com/IvanDobrovolsky/torchsight/releases/tag/${version}`} class="text-cyan-400 hover:text-cyan-300">Release notes</a>
      </p>
    </div>

    <footer class="pb-10 text-center border-t border-border-subtle pt-8 mt-10">
      <p class="text-text-dim text-xs font-mono">
        Apache 2.0 &middot; <a href="https://github.com/IvanDobrovolsky/torchsight" class="text-cyan-400 hover:text-cyan-300">GitHub</a>
      </p>
    </footer>
  </main>
</Layout>

<style>
  .os-btn {
    width: 140px;
    padding: 20px 16px;
    border-radius: 12px;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-deep);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
    font-family: inherit;
  }
  .os-btn:hover {
    border-color: var(--color-border-visible);
    color: var(--color-text-secondary);
  }
  .os-btn-active {
    border-color: var(--color-violet-400, #a78bfa);
    color: var(--color-text-primary);
    background: var(--color-surface);
    box-shadow: 0 0 0 1px var(--color-violet-400, #a78bfa);
  }
  .download-btn {
    display: inline-block;
    padding: 16px 56px;
    background: var(--color-text-primary, white);
    color: var(--color-void, #07060F);
    font-family: 'Fira Code', monospace;
    font-size: 15px;
    font-weight: 600;
    border-radius: 999px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .download-btn:hover {
    opacity: 0.9;
  }
</style>

<script>
  // OS detection + tab switching
  const panels = ['macos', 'linux', 'windows'];

  function showOS(os) {
    panels.forEach(p => {
      document.getElementById(`panel-${p}`)?.classList.toggle('hidden', p !== os);
      document.getElementById(`btn-${p}`)?.classList.toggle('os-btn-active', p === os);
    });
  }

  // Auto-detect OS
  const ua = navigator.userAgent.toLowerCase();
  if (ua.includes('win')) showOS('windows');
  else if (ua.includes('linux')) showOS('linux');
  else showOS('macos');

  // Tab click handlers
  panels.forEach(os => {
    document.getElementById(`btn-${os}`)?.addEventListener('click', () => showOS(os));
  });

  // Copy button
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.getAttribute('data-copy') || '';
      navigator.clipboard.writeText(text).then(() => {
        const orig = btn.innerHTML;
        btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
        setTimeout(() => { btn.innerHTML = orig; }, 1500);
      });
    });
  });
</script>
