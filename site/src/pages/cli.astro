---
import Layout from '../layouts/Layout.astro';
import { VERSION } from '../version';

const version = VERSION;
const repo = 'https://github.com/IvanDobrovolsky/torchsight/releases/download';
const dl = {
  macosArm: `${repo}/${version}/torchsight-macos-arm64`,
  macosIntel: `${repo}/${version}/torchsight-macos-x86_64`,
  linux: `${repo}/${version}/torchsight-linux-x86_64`,
  windows: `${repo}/${version}/torchsight-windows-x86_64.exe`,
};
---

<Layout title="CLI — TorchSight">
  <main class="max-w-4xl mx-auto px-6 py-14">
    <div class="flex justify-center mb-6 select-none">
      <img src="/ascii-logo.svg" alt="torchsight" class="w-full max-w-lg" />
    </div>
    <p class="text-text-muted text-sm mb-10 text-center">Install and use TorchSight from the terminal.</p>

    <!-- Install -->
    <h2 class="text-xs font-mono text-violet-400 tracking-widest mb-4">INSTALL</h2>

    <!-- macOS / Linux -->
    <div id="install-unix" class="space-y-4 mb-6">
      <div>
        <p class="text-text-dim text-xs font-mono mb-1">Quick install (macOS / Linux)</p>
        <pre class="bg-deep border border-border-subtle rounded-lg p-4 text-sm font-mono text-text-secondary overflow-x-auto">curl -sSL https://torchsight.io/install.sh | sh</pre>
      </div>
      <div class="flex gap-3">
        <a id="dl-primary" href={dl.macosArm} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono border border-border-visible rounded-lg px-4 py-2 hover:border-violet-500/40 transition-colors">Download binary</a>
        <a id="dl-alt" href={dl.macosIntel} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono border border-border-subtle rounded-lg px-4 py-2 hover:border-violet-500/40 transition-colors">Intel</a>
      </div>
    </div>

    <!-- Windows -->
    <div id="install-windows" class="mb-6 hidden">
      <div>
        <p class="text-text-dim text-xs font-mono mb-1">PowerShell (installs Ollama + Tesseract + models + TorchSight)</p>
        <pre class="bg-deep border border-border-subtle rounded-lg p-4 text-sm font-mono text-text-secondary overflow-x-auto">irm https://torchsight.io/install.ps1 | iex</pre>
      </div>
      <div class="flex gap-3 mt-4">
        <a href={dl.windows} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono border border-border-visible rounded-lg px-4 py-2 hover:border-violet-500/40 transition-colors">CLI only (.exe)</a>
      </div>
    </div>

    <div class="space-y-4 mb-14">
      <div>
        <p class="text-text-dim text-xs font-mono mb-1">From source</p>
        <pre class="bg-deep border border-border-subtle rounded-lg p-4 text-sm font-mono text-text-secondary overflow-x-auto"><code>git clone https://github.com/IvanDobrovolsky/torchsight
cd torchsight && make install</code></pre>
      </div>
    </div>

    <!-- Usage -->
    <h2 class="text-xs font-mono text-violet-400 tracking-widest mb-4">USAGE</h2>
    <div class="bg-deep border border-border-subtle rounded-lg overflow-hidden mb-14">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border-subtle">
        <div class="w-2.5 h-2.5 rounded-full bg-error/60"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-warning/60"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-success/60"></div>
        <span class="ml-2 text-xs text-text-dim font-mono">terminal</span>
      </div>
      <pre class="p-5 text-sm font-mono text-text-secondary leading-relaxed overflow-x-auto"><code><span class="text-text-muted"># scan a directory</span>
<span class="text-cyan-400">$</span> torchsight /path/to/files

<span class="text-text-muted"># interactive REPL</span>
<span class="text-cyan-400">$</span> torchsight

<span class="text-text-muted"># output formats: json, sarif, markdown, html</span>
<span class="text-cyan-400">$</span> torchsight /path --format sarif

<span class="text-text-muted"># CI mode — exit 1 if findings at or above severity</span>
<span class="text-cyan-400">$</span> torchsight /path --fail-on high

<span class="text-text-muted"># scan changed files since a git ref</span>
<span class="text-cyan-400">$</span> torchsight --diff HEAD~3

<span class="text-text-muted"># pipe mode</span>
<span class="text-cyan-400">$</span> cat file.txt | torchsight --stdin</code></pre>
    </div>

    <!-- Supported files -->
    <h2 class="text-xs font-mono text-violet-400 tracking-widest mb-4">SUPPORTED FILE TYPES</h2>
    <div class="flex flex-wrap gap-2 mb-14">
      {['PDF', 'DOCX', 'XLSX', 'PPTX', 'DOC', 'CSV', 'EML', 'PST', 'PNG', 'JPG', 'TIFF', 'TXT', 'JSON', 'YAML', 'XML'].map(ext => (
        <span class="px-2.5 py-1 text-xs font-mono text-text-muted bg-surface border border-border-subtle rounded">{ext}</span>
      ))}
    </div>

    <footer class="pb-10 text-center border-t border-border-subtle pt-8">
      <p class="text-text-dim text-xs font-mono">
        {version} &middot; Apache 2.0 &middot; <a href="https://github.com/IvanDobrovolsky/torchsight" class="text-cyan-400 hover:text-cyan-300">GitHub</a>
      </p>
    </footer>
  </main>
</Layout>

<script>
  const ua = navigator.userAgent.toLowerCase();
  const isWin = ua.includes('win');
  const isLinux = ua.includes('linux');

  if (isWin) {
    document.getElementById('install-unix')?.classList.add('hidden');
    document.getElementById('install-windows')?.classList.remove('hidden');
  } else if (isLinux) {
    const primary = document.getElementById('dl-primary');
    const alt = document.getElementById('dl-alt');
    if (primary) { primary.textContent = 'Download binary (x86_64)'; primary.href = primary.href.replace('macos-arm64', 'linux-x86_64'); }
    if (alt) alt.style.display = 'none';
  }
</script>
