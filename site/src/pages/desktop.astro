---
import Layout from '../layouts/Layout.astro';
import { VERSION } from '../version';

const version = VERSION;
const repo = 'https://github.com/IvanDobrovolsky/torchsight/releases/download';
const v = version.replace('v', '');
const dl = {
  macos: `${repo}/${version}/TorchSight_${v}_aarch64.dmg`,
  linux: `${repo}/${version}/TorchSight_${v}_amd64.AppImage`,
  linuxDeb: `${repo}/${version}/TorchSight_${v}_amd64.deb`,
  windows: `${repo}/${version}/TorchSight_${v}_x64-setup.exe`,
};
---

<Layout title="Desktop — TorchSight">
  <main class="max-w-4xl mx-auto px-6 py-14">
    <div class="flex justify-center mb-6 select-none">
      <img src="/ascii-logo.svg" alt="torchsight" class="w-full max-w-lg" />
    </div>
    <p class="text-text-muted text-sm mb-10 text-center">Native desktop app built with Tauri v2. Same scanning engine as the CLI.</p>

    <!-- Download -->
    <h2 class="text-xs font-mono text-violet-400 tracking-widest mb-4">DOWNLOAD</h2>

    <div class="text-center mb-10">
      <a id="dl-btn" href={dl.macos} class="inline-block px-10 py-3.5 bg-white text-void font-mono text-sm font-semibold rounded-full hover:opacity-90 transition-opacity" id="download-btn">
        Download for macOS
      </a>
      <p id="dl-desc" class="text-text-dim text-xs mt-3 font-mono">Apple Silicon (.dmg)</p>
      <div id="dl-alt-links" class="flex justify-center gap-4 mt-3">
        <a href={dl.macos} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono dl-macos">macOS</a>
        <a href={dl.linux} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono dl-linux">Linux AppImage</a>
        <a href={dl.linuxDeb} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono dl-linux">Linux .deb</a>
        <a href={dl.windows} class="text-cyan-400 hover:text-cyan-300 text-xs font-mono dl-win">Windows</a>
      </div>
    </div>

    <!-- Requirements -->
    <h2 class="text-xs font-mono text-violet-400 tracking-widest mb-4">SETUP</h2>
    <div class="bg-deep border border-border-subtle rounded-lg p-5 mb-14">
      <ol class="space-y-3 text-xs text-text-muted list-decimal list-inside">
        <li>Install <a href="https://ollama.com/download" class="text-cyan-400 hover:text-cyan-300">Ollama</a></li>
        <li>Pull the model: <code class="text-text-dim font-mono">ollama pull torchsight/beam</code></li>
        <li>Launch TorchSight</li>
      </ol>
    </div>

    <!-- Build from source -->
    <h2 class="text-xs font-mono text-violet-400 tracking-widest mb-4">BUILD FROM SOURCE</h2>
    <div class="bg-deep border border-border-subtle rounded-lg overflow-hidden mb-14">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border-subtle">
        <div class="w-2.5 h-2.5 rounded-full bg-error/60"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-warning/60"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-success/60"></div>
        <span class="ml-2 text-xs text-text-dim font-mono">terminal</span>
      </div>
      <pre class="p-5 text-sm font-mono text-text-secondary leading-relaxed overflow-x-auto"><code><span class="text-text-muted"># prerequisites: Rust, Node.js, system deps</span>
<span class="text-text-muted"># see https://v2.tauri.app/start/prerequisites/</span>

<span class="text-cyan-400">$</span> git clone https://github.com/IvanDobrovolsky/torchsight
<span class="text-cyan-400">$</span> cd torchsight/desktop
<span class="text-cyan-400">$</span> npm install
<span class="text-cyan-400">$</span> npm run tauri build</code></pre>
    </div>

    <footer class="pb-10 text-center border-t border-border-subtle pt-8">
      <p class="text-text-dim text-xs font-mono">
        {version} &middot; Apache 2.0 &middot; <a href="https://github.com/IvanDobrovolsky/torchsight" class="text-cyan-400 hover:text-cyan-300">GitHub</a>
      </p>
    </footer>
  </main>
</Layout>

<script>
  const ua = navigator.userAgent.toLowerCase();
  const btn = document.getElementById('dl-btn');
  const desc = document.getElementById('dl-desc');

  if (ua.includes('win') && btn && desc) {
    btn.textContent = 'Download for Windows';
    btn.href = btn.href.replace(/TorchSight.*\.dmg/, btn.href.replace(/.*\//, '').replace('aarch64.dmg', 'x64-setup.exe'));
    desc.textContent = 'Windows 10+ installer (.exe)';
  } else if (ua.includes('linux') && btn && desc) {
    btn.textContent = 'Download for Linux';
    btn.href = btn.href.replace(/TorchSight.*\.dmg/, btn.href.replace(/.*\//, '').replace('aarch64.dmg', 'amd64.AppImage'));
    desc.textContent = 'x86_64 AppImage';
  }
</script>
