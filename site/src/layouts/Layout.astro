---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'TorchSight — On-Premise Security Scanner',
  description = 'Open-source security scanner and document classifier powered by local LLMs.'
} = Astro.props;

const ogImage = '/og.png';
const siteUrl = 'https://torchsight.io';
const currentPath = Astro.url.pathname;

const nav = [
  { label: 'Home', href: '/' },
  { label: 'Download', href: '/download/' },
  { label: 'CLI', href: '/cli/' },
  { label: 'Desktop', href: '/desktop/' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <meta name="robots" content="index, follow" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:site_name" content="TorchSight" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen">
  <nav class="fixed top-0 left-0 right-0 z-50 bg-void/80 backdrop-blur-md border-b border-border-subtle">
    <div class="max-w-3xl mx-auto px-6 h-12 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-text-secondary hover:text-text-primary transition-colors">
        <img src="/logo.svg" alt="" class="w-5 h-5" />
        <span class="text-xs font-mono tracking-[0.15em]">TORCHSIGHT</span>
      </a>
      <div class="flex items-center gap-6">
        {nav.map(({ label, href }) => (
          <a
            href={href}
            class:list={[
              'text-xs font-mono transition-colors',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-violet-400'
                : 'text-text-muted hover:text-text-secondary',
            ]}
          >
            {label}
          </a>
        ))}
      </div>
    </div>
  </nav>
  <div class="pt-12">
    <slot />
  </div>
</body>
</html>
